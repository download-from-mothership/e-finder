# ── E-FINDER — Environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Anthropic API key (Claude) — used by swarm, courthouse_debate, intelligence_orchestrator
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used by Weaviate text2vec-openai vectorizer
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────

# Dashboard port (default: 5000)
DASHBOARD_PORT=5000

# Weaviate URL (default: http://weaviate:8080 inside Docker, http://localhost:8080 outside)
WEAVIATE_URL=http://weaviate:8080

# Path to the PDF library on the host machine (mounted read-only into containers)
# Leave blank or set to /dev/null if PDFs are not on this machine
PDF_LIBRARY_PATH=/path/to/doj_full_library

# Geocoding API key (optional — Nominatim/OpenStreetMap is used for free if not set)
GEOCODING_API_KEY=

# Cloudflare Tunnel token — from Zero Trust > Networks > Tunnels > efinder > Configure
# Run on VPS to find existing token: ps aux | grep cloudflared
# Or: systemctl cat cloudflared | grep token
CLOUDFLARE_TUNNEL_TOKEN=REDACTED_TUNNEL_TOKEN
